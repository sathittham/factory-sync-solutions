{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared UI components, lib helpers, and brand/favicon assets consumed by the FactorySync apps via the @shared/* alias.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "lint": "biome check ui/chat-widget",
    "lint:fix": "biome check --fix ui/chat-widget"
  },
  "exports": {
    "./ui/chat-widget": "./ui/chat-widget/index.ts",
    "./ui/*": "./ui/*",
    "./lib/*": "./lib/*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@tanstack/react-query": ">=5"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@tanstack/react-query": "^5.101.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
