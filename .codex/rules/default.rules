# FactorySync command policy for shell execution.
#
# Keep destructive shortcuts blocked. Release branch promotion commands are
# allowlisted because the repo release flow depends on repeated, audited git
# fetch/switch/merge/tag/push operations.

prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Do not discard local work; inspect diffs and ask for an explicit recovery plan instead.",
    match = ["git reset --hard", "git reset --hard HEAD~1"],
)

prefix_rule(
    pattern = ["git", "clean"],
    decision = "forbidden",
    justification = "Do not remove untracked files automatically; ask before cleanup and list affected paths first.",
    match = ["git clean -fd", "git clean -fdx"],
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "forbidden",
    justification = "Broad recursive deletion is blocked; use targeted edits or ask for explicit cleanup approval.",
    match = ["rm -rf dist", "rm -rf node_modules"],
)

prefix_rule(
    pattern = ["git", "fetch"],
    decision = "allow",
    justification = "Release flow must refresh remote branches and tags before promotion.",
    match = ["git fetch origin --prune --tags"],
)

prefix_rule(
    pattern = ["git", "switch"],
    decision = "allow",
    justification = "Release flow switches between develop, staging, main, and feature branches.",
    match = ["git switch develop", "git switch staging", "git switch main"],
)

prefix_rule(
    pattern = ["git", "merge"],
    decision = "allow",
    justification = "Release flow promotes branches with fast-forward merges and reconciles main into develop.",
    match = ["git merge --ff-only origin/feature/example", "git merge --ff-only develop", "git merge --no-edit origin/main"],
)

prefix_rule(
    pattern = ["git", "tag"],
    decision = "allow",
    justification = "Release flow creates staging and production version tags after branch promotion checks.",
    match = ["git tag v1.2.3", "git tag v1.2.3-staging"],
)

prefix_rule(
    pattern = ["git", "push", "origin"],
    decision = "allow",
    justification = "Release flow pushes promoted branches and release tags to the origin remote.",
    match = ["git push origin develop", "git push origin staging v1.2.3-staging", "git push origin main v1.2.3"],
)

prefix_rule(
    pattern = ["gh", "run", "list"],
    decision = "allow",
    justification = "Release verification needs read-only GitHub Actions run summaries after pushes and tags.",
    match = ["gh run list --repo sathittham/factory-sync-solutions --limit 10"],
)

prefix_rule(
    pattern = ["gh", "run", "view"],
    decision = "allow",
    justification = "Release troubleshooting needs read-only access to failed GitHub Actions logs.",
    match = ["gh run view 123456789 --repo sathittham/factory-sync-solutions --log-failed"],
)

prefix_rule(
    pattern = ["gh", "run", "watch"],
    decision = "allow",
    justification = "Release verification needs to watch deploy workflows until completion.",
    match = ["gh run watch 123456789 --repo sathittham/factory-sync-solutions --exit-status"],
)

prefix_rule(
    pattern = ["gh", "secret", "list"],
    decision = "allow",
    justification = "Release troubleshooting may need to confirm secret names exist without reading secret values.",
    match = ["gh secret list --repo sathittham/factory-sync-solutions"],
)

prefix_rule(
    pattern = ["python3", "/Users/sathittham/.codex/skills/.system/skill-creator/scripts/init_skill.py"],
    decision = "allow",
    justification = "Repo-local workflow setup may initialize project skills under .agents/skills.",
    match = ["python3 /Users/sathittham/.codex/skills/.system/skill-creator/scripts/init_skill.py release-flow --path .agents/skills --resources scripts"],
)

prefix_rule(
    pattern = ["python3", "/Users/sathittham/.codex/skills/.system/skill-creator/scripts/quick_validate.py"],
    decision = "allow",
    justification = "Skill validation is a read/check operation used after editing repo-local skills.",
    match = ["python3 /Users/sathittham/.codex/skills/.system/skill-creator/scripts/quick_validate.py .agents/skills/release-flow"],
)

prefix_rule(
    pattern = ["chmod", "+x", ".agents/skills/release-flow/scripts/release-flow.sh"],
    decision = "allow",
    justification = "The repo release-flow helper script must be executable.",
    match = ["chmod +x .agents/skills/release-flow/scripts/release-flow.sh"],
)

prefix_rule(
    pattern = [".agents/skills/release-flow/scripts/release-flow.sh"],
    decision = "allow",
    justification = "The guarded release-flow helper encapsulates the approved branch promotion and tag workflow.",
    match = [
        ".agents/skills/release-flow/scripts/release-flow.sh --target staging --feature feature/example --version v1.2.3",
        ".agents/skills/release-flow/scripts/release-flow.sh --target production --version v1.2.3",
        ".agents/skills/release-flow/scripts/release-flow.sh --target both --feature feature/example --version v1.2.3",
    ],
)

prefix_rule(
    pattern = ["make", "docs-api"],
    decision = "allow",
    justification = "Swagger/OpenAPI generation is a local build step that may need normal Go build cache access.",
    match = ["make docs-api"],
)

prefix_rule(
    pattern = ["npm", "run", "deploy:staging"],
    decision = "prompt",
    justification = "Staging deploys publish externally and should be confirmed.",
    match = ["npm run deploy:staging"],
)

prefix_rule(
    pattern = ["npm", "run", "deploy:prod"],
    decision = "prompt",
    justification = "Production deploys publish externally and should be confirmed.",
    match = ["npm run deploy:prod"],
)

prefix_rule(
    pattern = [
        "npx",
        "wrangler",
        "pages",
        "deploy",
        "dist",
        "--project-name=factory-sync-solutions",
        "--branch=main",
        "--account-id=9cfbba8b3a373fdc0d11abaf64071719",
    ],
    decision = "allow",
    justification = "Allow repeated production user-app Pages artifact deploys after explicit task approval.",
    match = [
        "npx wrangler pages deploy dist --project-name=factory-sync-solutions --branch=main --account-id=9cfbba8b3a373fdc0d11abaf64071719",
    ],
)

prefix_rule(
    pattern = [
        "npx",
        "wrangler",
        "pages",
        "deploy",
        "dist",
        "--project-name=factory-sync-backoffice",
        "--branch=main",
        "--account-id=9cfbba8b3a373fdc0d11abaf64071719",
    ],
    decision = "allow",
    justification = "Allow repeated production backoffice Pages artifact deploys after explicit task approval.",
    match = [
        "npx wrangler pages deploy dist --project-name=factory-sync-backoffice --branch=main --account-id=9cfbba8b3a373fdc0d11abaf64071719",
    ],
)

prefix_rule(
    pattern = [
        "npx",
        "wrangler",
        "pages",
        "deploy",
        "dist",
        "--project-name=factory-sync-solutions-official",
        "--branch=main",
        "--account-id=9cfbba8b3a373fdc0d11abaf64071719",
    ],
    decision = "allow",
    justification = "Allow repeated production official-site Pages artifact deploys after explicit task approval.",
    match = [
        "npx wrangler pages deploy dist --project-name=factory-sync-solutions-official --branch=main --account-id=9cfbba8b3a373fdc0d11abaf64071719",
    ],
)
