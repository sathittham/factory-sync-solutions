# ============================================
# Frontend Environment Variables (apps/web/.env.local)
# ============================================

# Firebase (public config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# API
VITE_API_BASE_URL=http://localhost:8080

# Cloudflare Turnstile (public site key)
VITE_CF_TURNSTILE_SITE_KEY=

# Google Analytics
VITE_GA_MEASUREMENT_ID=

# ============================================
# Backend Environment Variables (apps/api/)
# ============================================

# GCP
GCP_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT=           # path to service account JSON (local dev only)

# Email
RESEND_API_KEY=

# Cloudflare Turnstile (server-side secret)
CF_TURNSTILE_SECRET_KEY=

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Slack Webhooks
SLACK_WEBHOOK_REGISTRATIONS=
SLACK_WEBHOOK_QUIZ_RESULTS=
SLACK_WEBHOOK_SERVER_STATUS=

# Server
PORT=8080
ENVIRONMENT=development              # development | staging | production
