rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — profile data
    match /users/{uid} {
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == uid;

      // Users can create their own profile (once)
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.role == 'user';

      // Users can update their own profile (except role and avatarURL, which
      // are backend-only — avatarURL is written exclusively by the upload
      // service via the Admin SDK after image validation/processing)
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.avatarURL == resource.data.avatarURL;

      // Admin can read any profile
      allow read: if request.auth != null
                  && request.auth.token.role == 'admin';
    }

    // Assessments collection — quiz results
    match /assessments/{assessmentId} {
      // Users can read their own assessments
      allow read: if request.auth != null
                  && resource.data.uid == request.auth.uid;

      // Only the backend (via Admin SDK) creates assessments
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      // Admin can read all assessments
      allow read: if request.auth != null
                  && request.auth.token.role == 'admin';
    }

    // Email jobs collection — notification tracking
    match /email_jobs/{jobId} {
      // Only the backend (via Admin SDK) manages email jobs
      allow read, write: if false;
    }

    // Conversations collection — AI support chatbot transcripts (PII)
    match /conversations/{conversationId} {
      // Only the backend (via Admin SDK) reads/writes conversations
      allow read, write: if false;

      match /messages/{messageId} {
        allow read, write: if false;
      }
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
