# Copy to .env.e2e.local (gitignored) and fill in real values.
# Used by playwright.config.ts to log in as a test account.

# Credentials for an existing registered test account.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# Set to run against a deployed app instead of the local dev server,
# e.g. https://app-staging.factorysyncsolutions.com
E2E_BASE_URL=
