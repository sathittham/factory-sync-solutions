# Copy to .env.e2e.local (gitignored) and fill in real values.
# Used by playwright.config.ts to log in as a test backoffice account.

# Credentials for an existing backoffice superadmin account.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=

# Credentials for a non-superadmin staff account — used to verify
# SuperAdminGuard redirects staff off superadmin-only routes.
# Provision with: apps/backend/cmd/set-superadmin --role staff --create
E2E_STAFF_USER_EMAIL=
E2E_STAFF_USER_PASSWORD=

# Set to run against a deployed app instead of the local dev server,
# e.g. https://backoffice-staging.factorysyncsolutions.com
E2E_BASE_URL=
