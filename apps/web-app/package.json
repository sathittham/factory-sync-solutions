{
  "name": "@repo/web-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "sync:favicon": "node ../../packages/shared/scripts/copy-favicon.mjs public",
    "dev": "pnpm run sync:favicon && vite",
    "build": "pnpm run sync:favicon && tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "type-check": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "build:staging": "pnpm run sync:favicon && tsc -b && vite build --mode staging",
    "deploy:staging": "pnpm run build:staging && CLOUDFLARE_ACCOUNT_ID=9cfbba8b3a373fdc0d11abaf64071719 npx wrangler pages deploy dist --project-name=factory-sync-solutions-staging --branch=staging",
    "deploy:prod": "pnpm run build && CLOUDFLARE_ACCOUNT_ID=9cfbba8b3a373fdc0d11abaf64071719 npx wrangler pages deploy dist --project-name=factory-sync-solutions --branch=main"
  },
