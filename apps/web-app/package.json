    "@radix-ui/react-tooltip": "^1.2.9",
    "@reduxjs/toolkit": "^2.5.0",
    "@tanstack/react-form": "^1.33.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "firebase": "^11.0.0",
    "lucide-react": "^0.468.0",
    "motion": "^12.35.0",
    "react": "^19.0.0",
