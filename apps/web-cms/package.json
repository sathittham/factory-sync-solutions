{
  "name": "@repo/web-cms",
  "version": "0.1.0",
  "private": true,
  "description": "A SonicJS headless CMS application",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy --env production",
    "db:migrate": "wrangler d1 migrations apply DB",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:staging": "wrangler d1 migrations apply DB --env staging --remote",
    "db:migrate:prod": "wrangler d1 migrations apply DB --env production --remote",
    "db:reset": "sonicjs-db-reset",
    "db:studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "update": "npm install @sonicjs-cms/core@latest --save",
    "update:beta": "npm install @sonicjs-cms/core@beta --save",
    "seed": "tsx scripts/seed-admin.ts",
    "seed:knowledge": "tsx scripts/seed-knowledge.ts",
    "seed:staging": "node scripts/seed-admin-remote.mjs staging",
    "seed:prod": "node scripts/seed-admin-remote.mjs production",
    "seed:knowledge:staging": "node scripts/seed-knowledge-remote.mjs staging",
    "seed:knowledge:prod": "node scripts/seed-knowledge-remote.mjs production",
    "cf:setup:staging": "bash scripts/setup-cloudflare.sh staging",
    "cf:setup:prod": "bash scripts/setup-cloudflare.sh production"
  },
  "dependencies": {
    "@sonicjs-cms/core": "^3.0.0-beta.19",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20251202.0",
    "@types/node": "^24.10.1",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.10.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15",
    "wrangler": "^4.52.1",
    "zod": "^4.1.13"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
