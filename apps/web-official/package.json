{
	"name": "@repo/web-official",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"sync:favicon": "node ../../packages/shared/scripts/copy-favicon.mjs public",
		"dev": "pnpm run sync:favicon && astro dev",
		"build": "pnpm run sync:favicon && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:install": "playwright install --with-deps",
		"build:staging": "pnpm run sync:favicon && astro build --mode staging",
		"deploy:staging": "pnpm run build:staging && CLOUDFLARE_ACCOUNT_ID=9cfbba8b3a373fdc0d11abaf64071719 npx wrangler pages deploy dist --project-name=factory-sync-solutions-official-staging --branch=staging",
		"deploy:prod": "pnpm run build && CLOUDFLARE_ACCOUNT_ID=9cfbba8b3a373fdc0d11abaf64071719 npx wrangler pages deploy dist --project-name=factory-sync-solutions-official --branch=main"
	},
	"dependencies": {
		"@repo/shared": "workspace:*",
		"@astrojs/react": "^6.0.0",
		"@astrojs/sitemap": "^3.7.3",
		"@hookform/resolvers": "^5.4.0",
		"@radix-ui/react-icons": "^1.3.2",
		"@radix-ui/react-select": "^2.3.0",
		"@tailwindcss/vite": "^4.3.0",
		"astro": "^7.0.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"firebase": "^12.14.0",
		"lucide-react": "^0.462.0",
		"motion": "^12.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-hook-form": "^7.78.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@playwright/test": "^1.60.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitest/coverage-v8": "^4.1.8",
		"typescript": "^5.7.2",
		"vitest": "^4.1.8"
	}
}
