---
import { LegalContent } from "../components/legal/LegalContent";
import Layout from "../layouts/Layout.astro";

const appUrl = import.meta.env.PUBLIC_APP_URL ?? "#";
const version = import.meta.env.PUBLIC_APP_VERSION ?? "dev";
---

<Layout
  title="ข้อกำหนดการใช้งาน — FactorySync Solutions"
  description="ข้อกำหนดและเงื่อนไขการใช้งานบริการ FactorySync Solutions"
>
  <LegalContent client:idle page="terms" appUrl={appUrl} version={version} />
</Layout>
