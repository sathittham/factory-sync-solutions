# GCP / Firebase
GCP_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# Firestore Emulator (uncomment to use local emulator)
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Server
PORT=8080
ENVIRONMENT=development
# APP_URL is used as the continue URL in Firebase password-reset / invite links.
# development: http://localhost:5173
# staging:     https://app-staging.factorysyncsolutions.com
# production:  https://app.factorysyncsolutions.com
APP_URL=http://localhost:5173

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# Email (Resend)
RESEND_API_KEY=

# Cloudflare Turnstile (server-side secret)
CF_TURNSTILE_SECRET=

# Slack Webhooks
SLACK_WEBHOOK_REGISTRATION=
SLACK_WEBHOOK_QUIZ_RESULT=

# Cloudflare R2 uploads
# S3 API endpoint is derived as:
# https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com
R2_ACCOUNT_ID=9cfbba8b3a373fdc0d11abaf64071719
R2_ACCESS_KEY_ID=
R2_ACCESS_KEY_SECRET=
# staging: uploads-factorysyncsolutions-com-staging
# production: uploads-factorysyncsolutions-com
R2_PUBLIC_BUCKET=uploads-factorysyncsolutions-com
# staging example: https://uploads-staging.factorysyncsolutions.com
# production example: https://uploads.factorysyncsolutions.com
R2_PUBLIC_BASE_URL=

# API docs publishing / backoffice Swagger viewer
# Local development can use "filesystem"; deployed environments use "r2".
API_DOCS_SOURCE=filesystem
API_DOCS_R2_ACCOUNT_ID=9cfbba8b3a373fdc0d11abaf64071719
API_DOCS_R2_ACCESS_KEY_ID=
API_DOCS_R2_ACCESS_KEY_SECRET=
API_DOCS_R2_BUCKET=apidoc-factorysyncsolutions-com-staging
# API_DOCS_R2_BUCKET=apidoc-factorysyncsolutions-com
API_DOCS_R2_PREFIX=openapi
API_DOCS_SUPPORTED_VERSIONS=v1
API_DOCS_DEFAULT_VERSION=v1
API_DOCS_LOCAL_DIR=docs
