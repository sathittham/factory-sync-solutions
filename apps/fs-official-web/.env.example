PUBLIC_APP_URL=https://app.factorysyncsolutions.com
PUBLIC_APP_VERSION=v0.0.0

# Google Tag Manager (container ID, e.g. GTM-XXXXXXX) — production only;
# leave empty on staging/dev so no tag loads
PUBLIC_GTM_ID=

# Firebase (public config — get from Firebase Console > Project Settings)
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=
PUBLIC_FIREBASE_PROJECT_ID=
PUBLIC_FIREBASE_STORAGE_BUCKET=
PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
PUBLIC_FIREBASE_APP_ID=

# Registration form — API base URL and Cloudflare Turnstile site key
PUBLIC_API_BASE_URL=
PUBLIC_CF_TURNSTILE_SITE_KEY=
