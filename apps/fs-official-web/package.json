{
	"name": "fs-official-web",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"sync:favicon": "node ../../packages/shared/scripts/copy-favicon.mjs public",
		"dev": "npm run sync:favicon && astro dev",
		"build": "npm run sync:favicon && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"build:staging": "npm run sync:favicon && astro build --mode staging",
		"deploy:staging": "npm run build:staging && npx wrangler pages deploy dist --project-name=factory-sync-solutions-official-staging --branch=staging",
		"deploy:prod": "npm run build && npx wrangler pages deploy dist --project-name=factory-sync-solutions-official --branch=main"
	},
	"dependencies": {
		"@astrojs/react": "^4.0.0",
		"@radix-ui/react-icons": "^1.3.2",
		"@tailwindcss/vite": "^4.3.0",
		"astro": "^6.4.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^0.462.0",
		"motion": "^12.0.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitest/coverage-v8": "^4.1.8",
		"typescript": "^5.7.2",
		"vitest": "^4.1.8"
	}
}
